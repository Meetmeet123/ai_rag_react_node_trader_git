# TradeForge AI — Frontend Environment
# When served behind the nginx reverse proxy, use same-origin paths.
VITE_API_URL=/api
VITE_WS_URL=/socket.io

# Local development defaults (uncomment when running `npm run dev` against a local backend)
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000/ws
