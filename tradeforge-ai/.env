# TradeForge AI — Environment Configuration

# App
APP_NAME=TradeForge AI
DEBUG=false
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (MongoDB)
MONGODB_URI=
MONGODB_DB_NAME=

# LLM Configuration
LLM_MODEL_NAME=microsoft/DialoGPT-medium
LLM_MAX_LENGTH=512
LLM_TEMPERATURE=0.7

# Training
TRAINING_INTERVAL_MINUTES=20
BATCH_SIZE=16
LEARNING_RATE=2e-5
EPOCHS=3

# Trading
DEFAULT_CAPITAL=1000000
DEFAULT_TIMEFRAME=15m
MAX_POSITIONS=10
MAX_DAILY_LOSS_PCT=2.0

# Angel One SmartAPI
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# Zerodha Kite
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Fyers
FYERS_APP_ID=
FYERS_SECRET_KEY=

# Upstox
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
