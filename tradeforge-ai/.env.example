# TradeForge AI — Environment Configuration
# Copy this to .env and fill in your values

# App
APP_NAME=TradeForge AI
DEBUG=false
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_URL=http://localhost:5173

# Celery + Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/tradeforge
MONGODB_DB_NAME=tradeforge

# LLM Configuration
LLM_MODEL_NAME=microsoft/DialoGPT-medium
LLM_MAX_LENGTH=512
LLM_TEMPERATURE=0.7

# Training
TRAINING_INTERVAL_MINUTES=20
BATCH_SIZE=16
LEARNING_RATE=2e-5
EPOCHS=3
DRIFT_THRESHOLD=0.05
MODEL_SHADOW_MODE=false

# Trading
DEFAULT_CAPITAL=1000000
DEFAULT_TIMEFRAME=15m
MAX_POSITIONS=10
MAX_DAILY_LOSS_PCT=2.0

# Angel One SmartAPI
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# Zerodha Kite
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Fyers
FYERS_APP_ID=
FYERS_SECRET_KEY=

# Upstox
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# MLflow experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=tradeforge

# S3-compatible artifact storage (MinIO in local Docker Compose)
ENABLE_S3_ARTIFACTS=false
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tradeforge-artifacts

# Encryption & error reporting
ENCRYPTION_KEY=
SENTRY_DSN=
